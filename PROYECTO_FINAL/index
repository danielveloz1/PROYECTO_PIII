<!DOCTYPE html>
<html lang="en">
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="estilos.css">

</head>
<body>
    <!-- Barra de navegación -->
    <nav class="navbar navbar-dark bg-dark">
        <a class="navbar-brand">PERFUMERIA </a>
        <div class="d-flex">
            <input class="form-control me-2" type="search" placeholder="Buscar">
            <button class="btn btn-outline-light">Buscar</button>
        </div>
    </nav>
    <section class="productos-section">
    <div class="container-fluid px-0">
      <div class="row g-0">
 
        <!-- Tarjeta 1 -->
        <div class="col-12 col-md-4">
          <div class="promo-card card-rosada">
            <div class="card-inner">
              <p class="card-subtitulo">Colección Exclusiva</p>
              <h2 class="card-titulo">Perfumes<br>de Verano</h2>
              <div class="card-badge">
                <span class="badge-numero">20%</span>
                <span class="badge-texto">OFF</span>
              </div>
              <p class="card-descripcion">En fragancias seleccionadas<br>del 11 al 30 de junio</p>
              <img src="perfume1.png" alt="Perfume verano" class="card-img-producto">
            </div>
            <div class="card-footer-promo bg-magenta">
              <p class="footer-titulo">20% off en Perfumes de Verano</p>
              <p class="footer-sub">Envío gratis en compras mayores a $50</p>
              <a href="#" class="footer-link">VER AHORA ›</a>
            </div>
          </div>
        </div>
 
        <!-- Tarjeta 2 -->
        <div class="col-12 col-md-4">
          <div class="promo-card card-crema">
            <div class="card-inner">
              <p class="card-subtitulo">Ofertas de Temporada</p>
              <h2 class="card-titulo">Fragancias<br>Destacadas</h2>
              <p class="card-fecha">Hasta el 30 de junio</p>
              <div class="card-badge badge-rojo">
                <span class="badge-pre">HASTA</span>
                <span class="badge-numero">50%</span>
                <span class="badge-texto">OFF</span>
              </div>
              <p class="card-descripcion">En belleza seleccionada</p>
              <img src="perfume2.png" alt="Fragancias destacadas" class="card-img-producto">
            </div>
            <div class="card-footer-promo bg-salmon">
              <p class="footer-titulo">Hasta 50% off en Fragancias</p>
              <p class="footer-sub">Acumula puntos con cada compra</p>
              <a href="#" class="footer-link">VER AHORA ›</a>
            </div>
          </div>
        </div>
 
        <!-- Tarjeta 3 -->
        <div class="col-12 col-md-4">
          <div class="promo-card card-lavanda">
            <div class="card-inner">
              <p class="card-subtitulo">Nueva Colección</p>
              <h2 class="card-titulo">Aromas<br>Irresistibles</h2>
              <p class="card-descripcion">Descubre nuestra línea premium<br>de perfumes importados</p>
              <img src="perfume3.png" alt="Nueva colección" class="card-img-producto">
            </div>
            <div class="card-footer-promo bg-azul">
              <p class="footer-titulo">Hidratación Visible y Duradera</p>
              <p class="footer-sub">Obtén 20% off en marcas seleccionadas</p>
              <a href="#" class="footer-link">NO TE LO PIERDAS ›</a>
            </div>
          </div>
        </div>
 
      </div>
    </div>
  </section>
    <footer>
        <div class="footer-main">
        <div class="row g-4">
    
            <!-- Columna 1: Perfumeria -->
            <div class="col-6 col-md-2">
            <div class="footer-title">La Empresa</div>
            <a class="footer-link" href="#">Acerca de las Fragancias</a>
            <a class="footer-link" href="#">Ventas al por mayor</a>
            <a class="footer-link" href="#">Política de privacidad</a>
            <a class="footer-link" href="#">Política de entrega</a>
            <a class="footer-link" href="#">Tiendas</a>
            </div>
    
            <!-- Columna 2: Servicio al Cliente -->
            <div class="col-6 col-md-3">
            <div class="footer-title">Servicio al Cliente</div>
            <a class="footer-link" href="#">Contáctanos</a>
            <a class="footer-link" href="#">Centro de ayuda</a>
            <a class="footer-link" href="#">Términos y condiciones</a>
            <a class="footer-link" href="#">Comprobantes electrónicos</a>
            </div>
    
            <!-- Columna 3: Mi Cuenta -->
            <div class="col-6 col-md-2">
            <div class="footer-title">Mi Cuenta</div>
            <a class="footer-link" href="#">Mis compras</a>
            <a class="footer-link" href="#">Mis datos personales</a>
            </div>
    
            <!-- Columna 4: Newsletter y Pagos -->
            <div class="col-12 col-md-3">
            <div class="footer-title">¡Suscríbete a nuestro newsletter!</div>
            <div class="newsletter-form">
                <input class="newsletter-input" type="email" placeholder="Ingresa tu E-mail">
                <button class="newsletter-btn">&#8250;</button>
            </div>
            <div class="payment-logos">
                <!-- Metodos de pago -->
                <img src="img\MasterCard_Logo.png" alt="Mastercard" height="28">
                <img src="visa.png" alt="Visa" height="28">
                <img src="diners.png" alt="Diners Club" height="28">
                <img src="amex.png" alt="American Express" height="28">
                <img src="discover.png" alt="Discover" height="28">
            </div>
            </div>
    
            <!-- Columna 5: Redes sociales -->
            <div class="col-6 col-md-2">
            <div class="footer-title">Síguenos</div>
            <a class="social-icon" href="#" aria-label="TikTok">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.01a8.16 8.16 0 004.77 1.52V7.1a4.85 4.85 0 01-1-.41z"/>
                </svg>
            </a>
            <a class="social-icon" href="#" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
            </a>
            </div>
 
        </div>
        </div>
    
        <!-- Barra inferior -->
        <div class="footer-bottom d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span>Copyright &copy; 2026. Todos los derechos reservados. / Todas las marcas e imágenes usadas son propiedad de Pefumeria.</span>
        <span>Developed by <strong>TuEmpresa</strong></span>
        </div>
  </footer>

</body>
</html>
